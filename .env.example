# Voice & AI Configuration
# Get your key at https://elevenlabs.io/
VITE_ELEVEN_LABS_API_KEY=

# n8n Configuration
# Your webhook URL for triggering automated workflows
VITE_N8N_WEBHOOK_URL=

# Gemini API (Built-in environment variable, listed here for reference)
# Do not prefix with VITE_ as it is accessed via process.env.GEMINI_API_KEY
GEMINI_API_KEY=

# App Configuration
VITE_APP_URL=http://localhost:3000

# Other Integrations (Optional)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
VITE_TWILIO_PHONE_NUMBER=
VITE_CAL_LINK=
